@model List<Catalogo.Models.Item>
<div class="contenedor-principal">
<h1>Mi Catálogo</h1>

<div class="contenedor-filtros">
        <a asp-action="Index" class="filtro-btn">Todos</a>
    @foreach (var tip in ViewBag.Tipos as List<string>)
    {
        <span> | </span>
        <a asp-action="Index" asp-route-tipo= "@tip" class="filtro-btn">@tip</a>
    }
</div>

<hr class="divisor" />
<div class="grid-albumes">
    @foreach (var item in Model)
    {
      
           <a asp-action="Detalle" asp-route-id= "@item.Id" class="tarjeta-album">
            <h3>@item.Titulo</h3>
            <div class="tarjeta-info">
                    <span class="etiqueta-tipo">@item.tiposLanzamiento (@item.Ano)</span>
                    <span class="etiqueta-ano"></span>
            </div>
           
          
           </a>
    }
</div>
<hr />
<a asp-Action= "Agregar" class="btn-agregar-album">+ Agregar álbum</a>
</div>