@model Catalogo.Models.Item

<div class="detalle-titulo">
    <h1>@Model.Titulo</h1>
</div>
<div class="detalle-total">
    <div class"detalle-texto">
    <p><strong>Tipo de lanzamiento: </strong> @Model.tiposLanzamiento</p>

    <p><strong>Numero de canciones: </strong>@Model.numeroCanciones</p>

    <p><strong>Año: </strong>@Model.Ano</p>

    <p><strong>Descripción: </strong>@Model.Descripcion</p>
    </div>

    
</div>
<div class="bloque-canciones">
    <h2 class="titulo-seccion">Canciones</h2>
    
    <div class="contenedor-canciones-uniforme">
        <img src="~/images/canciones-@(@Model.Id).png" alt="Lista de canciones" class="imagen-canciones-ajustada" />
    </div>

</div>
<hr />
<a asp-action="Index" class="link-cancelar">&larr; Volver al Catálogo</a>

